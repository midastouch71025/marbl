# Copy to `.env` for local non-Compose runs. Docker Compose sets most of these inline;
# use this file as the canonical list of variables the binaries read from the environment.

# -----------------------------------------------------------------------------
# Shared
# -----------------------------------------------------------------------------
# Required for producer, consumer, and migrate.
# -----------------------------------------------------------------------------
# Docker Compose — published host ports (optional; defaults match README)
# -----------------------------------------------------------------------------
MARBL_POSTGRES_HOST_PORT=15432
MARBL_PROMETHEUS_HOST_PORT=9090
MARBL_GRAFANA_HOST_PORT=3000
MARBL_CONSUMER_HTTP_HOST_PORT=8080
MARBL_PRODUCER_METRICS_HOST_PORT=9091
MARBL_PRODUCER_PPROF_HOST_PORT=6060
MARBL_CONSUMER_METRICS_HOST_PORT=9092
MARBL_CONSUMER_PPROF_HOST_PORT=6061

# For tools on the host (psql, GUI) talking to the compose Postgres container:
DATABASE_URL=postgres://marbl:marbl@localhost:15432/marbl?sslmode=disable

# Grace period for in-flight work on SIGINT/SIGTERM (seconds).
SHUTDOWN_TIMEOUT_SECONDS=30

# Logging: LOG_LEVEL=debug|info|warn|error ; LOG_FORMAT=text|json
LOG_LEVEL=info
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Producer (cmd/producer) — set these in the producer process only
# -----------------------------------------------------------------------------
# HTTP base URL of the consumer (task POST endpoint). In Compose the producer uses the
# service name (see docker-compose.yml). For a producer on the host talking to Compose consumer:
# use http://localhost:<MARBL_CONSUMER_HTTP_HOST_PORT> (default 8080).
CONSUMER_URL=http://localhost:8080

# Prometheus /metrics and pprof listen on these ports (host ports in Compose: 9091, 6060).
PROMETHEUS_PORT=9091
PPROF_PORT=6060

# Max rows in received+processing before the generation loop pauses.
PRODUCER_MAX_BACKLOG=100

# Inserts per second (generation ticker = 1s / rate).
PRODUCER_RATE_PER_SEC=10

# -----------------------------------------------------------------------------
# Consumer (cmd/consumer) — set these in the consumer process only
# -----------------------------------------------------------------------------
LISTEN_ADDR=:8080

# Use different ports when running producer and consumer on the same host outside Compose.
# PROMETHEUS_PORT=9092
# PPROF_PORT=6061

# Sliding window rate limit: at most N tasks accepted per window duration.
CONSUMER_RATE_LIMIT_COUNT=50
CONSUMER_RATE_LIMIT_WINDOW=1s

# Reaper: processing rows with last_update older than this (seconds) reset to received.
CONSUMER_REAPER_STALE_SECONDS=5

# -----------------------------------------------------------------------------
# Docker image builds (docker compose build / docker build)
# -----------------------------------------------------------------------------
# Injected via -ldflags -X main.version=...
VERSION=dev

# Optional CPU profile file in the build context (e.g. default.pgo). When set, the
# Dockerfile copies it into each cmd/*/default.pgo and builds with -pgo=auto.
# PGO_PROFILE=default.pgo
